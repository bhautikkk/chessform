// ═══════════════════════════════════════════════════════════════
// ChessBird — Firestore Security Rules
//
// YEH RULES FIREBASE CONSOLE ME JAAKE DEPLOY KARNI HAIN:
//   Firebase Console → Firestore → Rules → Paste → Publish
// ═══════════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPER: Check if the request comes from a logged-in admin ──
    function isAdmin() {
      return request.auth != null;
    }

    // ── REGISTRATIONS COLLECTION ──────────────────────────────────
    match /registrations/{docId} {
      // ✅ Public can ONLY CREATE their own registration IF paymentId looks valid
      allow create: if request.resource.data.keys().hasAll(['paymentId']) 
                    && request.resource.data.paymentId is string 
                    && request.resource.data.paymentId.matches('^pay_.*')
                    && request.resource.data.paymentId.size() > 10;
      // 🚫 NO PUBLIC UPDATES - Stops hackers from altering someone else's data
      allow update: if false; 
      // 🚫 NO PUBLIC DELETING
      allow delete: if isAdmin();
      
      // ✅ Allow GET (reading a specific registration IF you know the exact phone number)
      // 🚫 DENY LIST (nobody can download the whole database from inspect element)
      allow get: if true;
      allow list: if isAdmin();
    }

    // ── USED CARDS COLLECTION (For duplicate checking safely) ───
    match /used_cards/{docId} {
      // ✅ Public can check if a Card ID exists, and reserve it
      allow get, create: if true;
      allow list, update, delete: if isAdmin();
    }

    // ── SETTINGS COLLECTION ──────────────────────────────────────
    match /settings/{docId} {
      // "global" doc — public read karein toggles ke liye
      allow read: if docId == "global";
      // Baki sab settings sirf admin create/edit/delete kar sakta hai
      allow write: if isAdmin();
    }

    // ── DEFAULT: Sab kuch deny ──────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
