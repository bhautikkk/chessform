// ═══════════════════════════════════════════════════════════════
// ChessBird — Firestore Security Rules  (Maximum Security Version)
//
// DEPLOY: Firebase Console → Firestore → Rules → Paste → Publish
// ═══════════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ══════════════════════════════════════════════════════════

    // Admin = ONLY the owner email (bhautikk264@gmail.com)
    // Even if someone else logs in via Firebase Auth, they get ZERO admin access.
    // Note: email_verified NOT checked because Email/Password login doesn't auto-verify.
    // Security is ensured by the unique password only the owner knows.
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email == "bhautikk264@gmail.com";
    }

    // ══════════════════════════════════════════════════════════
    // REGISTRATIONS (PUBLIC) — leaderboard, get-pass, duplicate check
    // Contains: name, username, phone, rating, cardId, points,
    //           matchStatus, currentRound
    // Does NOT contain: email, paymentId (those are in _private)
    // ══════════════════════════════════════════════════════════
    match /registrations/{docId} {

      // All registrations MUST go through the secure Vercel API backend.
      // Read access is also restricted to admin to protect Entry IDs (cardId).
      allow read, write: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════
    // REGISTRATIONS PRIVATE — admin-only sensitive data
    // Contains: email, paymentId, timestamp
    // NOBODY except admin can read this
    // ══════════════════════════════════════════════════════════
    match /registrations_private/{docId} {

      // ── ALL OPERATIONS: admin only ────────────────────
      // Creation is strictly handled via Vercel Backend.
      allow read, write: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════
    // PASS ATTEMPTS — server-side rate limiting for get-pass
    // Prevents localStorage bypass attack
    // ══════════════════════════════════════════════════════════
    match /pass_attempts/{docId} {
      // Frontend is no longer allowed to read/write attempts to prevent DoS.
      // Rate limiting is handled purely in the Vercel backend.
      allow read, write: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════
    // USED CARDS — duplicate card ID prevention
    // ══════════════════════════════════════════════════════════
    match /used_cards/{docId} {
      allow get: if true;
      allow create, list, update, delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════
    // SETTINGS — toggle controls
    // ══════════════════════════════════════════════════════════
    match /settings/{docId} {
      // Public can ONLY read 'global' doc (for registration open/leaderboard toggle)
      allow read: if docId == 'global';
      allow write: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════
    // PROMO CODES — admin-controlled discount codes
    // Public can only GET a specific code by exact ID (to validate).
    // Public CANNOT list all codes (enumeration blocked).
    // Only admin can create, update, or delete codes.
    // ══════════════════════════════════════════════════════════
    match /promo_codes/{codeId} {
      // Allow public to read a specific code doc (validate by exact ID only)
      allow get: if true;
      // Only admin can list, create, update, or delete codes
      allow list, create, update, delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════
    // PAIRINGS — Swiss Tournament Round Pairings
    // Admin creates pairings per round. Public can read.
    // ══════════════════════════════════════════════════════════
    match /pairings/{docId} {
      allow read: if true;          // Players can view pairings
      allow write: if isAdmin();    // Only admin can generate/edit
    }

    // ══════════════════════════════════════════════════════════
    // REJECTION HISTORY — tracking abuse and multiple rejections
    // ══════════════════════════════════════════════════════════
    match /rejection_history/{docId} {
      allow get: if true; // Needed for verifyPayment.js via Vercel or frontend checks
      allow list, create, update, delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════
    // DEFAULT: Deny everything not explicitly allowed
    // ══════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
